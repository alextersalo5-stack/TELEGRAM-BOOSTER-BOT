@bot.message_handler(commands=['orders'])
def show_orders(message):
    c.execute("SELECT id, service, quantity, price, status FROM orders WHERE user_id = ? ORDER BY id DESC LIMIT 5", (message.chat.id,))
    orders = c.fetchall()
    if not orders:
        bot.send_message(message.chat.id, "No orders yet.")
        return
    msg = "📋 Your recent orders:\n\n"
    for o in orders:
        svc = SERVICE_NAMES.get(o[1], o[1].title())
        msg += f"#{o[0]} | {svc} × {o[2]} | ₱{o[3]} | {o[4]}\n"
    bot.send_message(message.chat.id, msg)

